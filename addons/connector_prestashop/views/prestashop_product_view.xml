<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Vista formulario del binding — solo para ver estado y re-sincronizar -->
    <record id="view_prestashop_product_form" model="ir.ui.view">
        <field name="name">prestashop.product.form</field>
        <field name="model">prestashop.product</field>
        <field name="arch" type="xml">
            <form string="Producto en PrestaShop" create="0">
                <header>
                    <button name="sync_to_prestashop"
                            string="Re-sincronizar a PrestaShop"
                            type="object"
                            class="btn-primary"/>
                    <field name="sync_state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="alert alert-info" role="alert">
                        Este registro vincula un producto de Odoo con su equivalente en PrestaShop.
                        Para crear o editar productos, usa <b>Inventario → Productos</b>.
                    </div>
                    <group string="Producto Odoo">
                        <field name="odoo_product_id"/>
                        <field name="config_id"/>
                    </group>
                    <group string="Estado en PrestaShop">
                        <field name="prestashop_id"/>
                        <field name="prestashop_reference"/>
                        <field name="last_sync"/>
                        <field name="sync_message"/>
                    </group>
                    <notebook>
                        <page string="Combinaciones" name="combinations">
                            <field name="combination_ids" readonly="1">
                                <tree string="Combinaciones sincronizadas" create="0" delete="0">
                                    <field name="prestashop_combination_id" string="ID PS"/>
                                    <field name="odoo_variant_id" string="Variante Odoo"/>
                                    <field name="sync_state"
                                           string="Estado"
                                           decoration-success="sync_state == 'synced'"
                                           decoration-danger="sync_state == 'error'"/>
                                    <field name="last_sync" string="Última sync"/>
                                    <field name="sync_message" string="Mensaje"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vista lista — solo lectura, sin "Nuevo" -->
    <record id="view_prestashop_product_list" model="ir.ui.view">
        <field name="name">prestashop.product.list</field>
        <field name="model">prestashop.product</field>
        <field name="arch" type="xml">
            <tree string="Productos en PrestaShop" create="0" delete="0">
                <field name="odoo_product_id"/>
                <field name="prestashop_id"/>
                <field name="prestashop_reference"/>
                <field name="sync_state"
                       decoration-success="sync_state == 'synced'"
                       decoration-danger="sync_state == 'error'"
                       decoration-warning="sync_state == 'pending'"/>
                <field name="last_sync"/>
            </tree>
        </field>
    </record>

    <!-- Acción -->
    <record id="action_prestashop_product" model="ir.actions.act_window">
        <field name="name">Productos en PrestaShop</field>
        <field name="res_model">prestashop.product</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'create': False}</field>
    </record>

</odoo>
