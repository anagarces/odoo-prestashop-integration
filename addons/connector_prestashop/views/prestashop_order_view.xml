<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_prestashop_order_list" model="ir.ui.view">
        <field name="name">prestashop.order.list</field>
        <field name="model">prestashop.order</field>
        <field name="arch" type="xml">
            <tree string="Pedidos PrestaShop"
                  decoration-success="sync_state == 'synced'"
                  decoration-danger="sync_state == 'error'">
                <field name="prestashop_id" string="ID PS"/>
                <field name="prestashop_reference" string="Referencia PS"/>
                <field name="odoo_order_id"/>
                <field name="config_id"/>
                <field name="sync_state"/>
                <field name="last_sync"/>
            </tree>
        </field>
    </record>

    <record id="view_prestashop_order_form" model="ir.ui.view">
        <field name="name">prestashop.order.form</field>
        <field name="model">prestashop.order</field>
        <field name="arch" type="xml">
            <form string="Pedido PrestaShop">
                <sheet>
                    <group string="Pedido">
                        <field name="prestashop_id"/>
                        <field name="prestashop_reference"/>
                        <field name="odoo_order_id"/>
                        <field name="config_id"/>
                    </group>
                    <group string="Sincronización">
                        <field name="sync_state"/>
                        <field name="last_sync"/>
                        <field name="sync_message"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_prestashop_order" model="ir.actions.act_window">
        <field name="name">Pedidos PrestaShop</field>
        <field name="res_model">prestashop.order</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>
