<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_prestashop_category_form" model="ir.ui.view">
        <field name="name">prestashop.category.form</field>
        <field name="model">prestashop.category</field>
        <field name="arch" type="xml">
            <form string="Vínculo de Categoría">
                <header>
                    <button name="sync_to_prestashop"
                            string="Exportar a PrestaShop"
                            type="object"
                            class="btn-primary"
                            invisible="prestashop_id == 0"/>
                    <field name="sync_state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="alert alert-info" role="alert">
                        Vincula una categoría de Odoo con su equivalente en PrestaShop.
                        Para importar el árbol completo, usa <b>Configuración PrestaShop → Importar Categorías</b>.
                        Puedes crear bindings manuales aquí si ya existen ambas categorías.
                    </div>
                    <group string="Vínculo">
                        <field name="odoo_category_id"/>
                        <field name="config_id"/>
                        <field name="prestashop_id"
                               help="ID numérico de la categoría en PrestaShop. Déjalo en 0 para exportar como nueva categoría."/>
                    </group>
                    <group string="Estado de sincronización">
                        <field name="last_sync"/>
                        <field name="sync_message"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_prestashop_category_list" model="ir.ui.view">
        <field name="name">prestashop.category.list</field>
        <field name="model">prestashop.category</field>
        <field name="arch" type="xml">
            <tree string="Categorías vinculadas a PrestaShop">
                <field name="odoo_category_id"/>
                <field name="prestashop_id"/>
                <field name="sync_state"
                       decoration-success="sync_state == 'synced'"
                       decoration-danger="sync_state == 'error'"
                       decoration-warning="sync_state == 'pending'"/>
                <field name="last_sync"/>
                <field name="sync_message" optional="hide"/>
            </tree>
        </field>
    </record>

    <record id="action_prestashop_category" model="ir.actions.act_window">
        <field name="name">Categorías PrestaShop</field>
        <field name="res_model">prestashop.category</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>
