<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Hereda el formulario nativo de Contacts para añadir el smart button PS.
         No modifica ningún campo existente — solo añade visibilidad del vínculo PS. -->
    <record id="view_partner_prestashop_form" model="ir.ui.view">
        <field name="name">res.partner.form.prestashop</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <!-- Smart button en la caja de estadísticas del formulario nativo -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_prestashop_account"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-shopping-cart"
                        invisible="prestashop_customer_count == 0">
                    <field name="prestashop_customer_count"
                           widget="statinfo"
                           string="PrestaShop"/>
                </button>
            </xpath>
        </field>
    </record>

</odoo>
