<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Vista formulario de configuración -->
    <record id="view_prestashop_config_form" model="ir.ui.view">
        <field name="name">prestashop.config.form</field>
        <field name="model">prestashop.config</field>
        <field name="arch" type="xml">
            <form string="Configuración PrestaShop">
                <header>
                    <button name="test_connection"
                            string="Probar Conexión"
                            type="object"
                            class="btn-primary"/>
                    <button name="action_import_categories"
                            string="Importar Categorías"
                            type="object"
                            invisible="state != 'connected'"/>
                    <button name="action_export_products"
                            string="Exportar Productos"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'connected'"/>
                    <button name="action_import_customers"
                            string="Importar Clientes"
                            type="object"
                            invisible="state != 'connected'"/>
                    <button name="action_import_orders"
                            string="Importar Pedidos"
                            type="object"
                            invisible="state != 'connected'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group string="Conexión">
                        <field name="name"/>
                        <field name="url" placeholder="http://host.docker.internal:8080"/>
                        <field name="api_key" password="True"/>
                        <field name="active"/>
                    </group>
                    <group string="Defaults para sincronización">
                        <field name="default_lang_id"/>
                        <field name="default_category_ps_id"/>
                        <field name="default_tax_rules_group_id"/>
                    </group>
                    <group string="Última sincronización">
                        <field name="last_products_sync"/>
                        <field name="last_customer_sync"/>
                        <field name="last_sync"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vista lista de configuraciones -->
    <record id="view_prestashop_config_list" model="ir.ui.view">
        <field name="name">prestashop.config.list</field>
        <field name="model">prestashop.config</field>
        <field name="arch" type="xml">
           <tree string="Configuraciones PrestaShop">
                <field name="name"/>
                <field name="url"/>
                <field name="state"/>
                <field name="last_sync"/>
            </tree>
        </field>
    </record>

    <!-- Acción para abrir configuraciones -->
    <record id="action_prestashop_config" model="ir.actions.act_window">
        <field name="name">Configuración PrestaShop</field>
        <field name="res_model">prestashop.config</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>
