<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_prestashop_customer_list" model="ir.ui.view">
        <field name="name">prestashop.customer.list</field>
        <field name="model">prestashop.customer</field>
        <field name="arch" type="xml">
            <tree string="Clientes PrestaShop"
                  create="0"
                  decoration-success="sync_state == 'synced'"
                  decoration-danger="sync_state == 'error'">
                <field name="prestashop_id" string="ID PS"/>
                <field name="odoo_partner_id" string="Contacto Odoo"/>
                <field name="partner_email" string="Email" optional="show"/>
                <field name="partner_mobile" string="Teléfono" optional="show"/>
                <field name="sync_state" string="Estado"/>
                <field name="last_sync" optional="hide"/>
            </tree>
        </field>
    </record>

    <record id="view_prestashop_customer_form" model="ir.ui.view">
        <field name="name">prestashop.customer.form</field>
        <field name="model">prestashop.customer</field>
        <field name="arch" type="xml">
            <form string="Cliente PrestaShop" create="0">
                <header>
                    <field name="sync_state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button type="object"
                                name="action_open_partner"
                                class="oe_stat_button"
                                icon="fa-user">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text">Ver Contacto</span>
                            </div>
                        </button>
                    </div>
                    <group string="Vínculo Odoo ↔ PrestaShop">
                        <field name="prestashop_id" string="ID en PrestaShop"/>
                        <field name="odoo_partner_id" string="Contacto Odoo"/>
                        <field name="config_id"/>
                    </group>
                    <group string="Datos del contacto">
                        <field name="partner_email"/>
                        <field name="partner_mobile"/>
                        <field name="partner_street"/>
                        <field name="partner_city"/>
                    </group>
                    <group string="Sincronización">
                        <field name="last_sync"/>
                        <field name="sync_message"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_prestashop_customer" model="ir.actions.act_window">
        <field name="name">Clientes PrestaShop</field>
        <field name="res_model">prestashop.customer</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>
