# ─── PRESTASHOP CONFIG ────────────────────────────────────────
# Clave generada en PrestaShop → Parámetros Avanzados → Webservice
PRESTASHOP_API_KEY=tu_api_key_aqui
PRESTASHOP_ADMIN_MAIL=admin@tudominio.com
PRESTASHOP_ADMIN_PASSWD=tu_password_admin_prestashop

# ─── ODOO CONFIG ──────────────────────────────────────────────
ODOO_ADMIN_PASSWD=tu_password_admin_odoo

# ─── POSTGRES CONFIG (ODOO DB) ────────────────────────────────
POSTGRES_USER=odoo
POSTGRES_PASSWORD=tu_password_postgres
POSTGRES_DB=stylesync

# ─── MYSQL CONFIG (PRESTASHOP DB) ─────────────────────────────
MYSQL_ROOT_PASSWORD=tu_password_root_mysql
MYSQL_DATABASE=prestashop
MYSQL_USER=psuser
MYSQL_PASSWORD=tu_password_mysql
